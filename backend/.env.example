# ── Supabase project ─────────────────────────────────────────────────────────
SUPABASE_URL=https://eselafyxpgsbndrcknfy.supabase.co

# Service-role key — bypasses RLS for server-side inserts.
# Find it in: Supabase Dashboard → Settings → API → Project API Keys → service_role
# NEVER expose this value to frontend code or VITE_ variables.
SUPABASE_SECRET_KEY=

# JWT secret — used to validate signed-in user access tokens.
# Find it in: Supabase Dashboard → Settings → API → JWT Settings → JWT Secret
# This is different from the service_role key. Do NOT use the anon key here.
SUPABASE_JWT_SECRET=

# ── CORS ─────────────────────────────────────────────────────────────────────
# Origin of the Vite development server (or production frontend URL).
# Only this origin is allowed to make cross-origin requests to the backend.
FRONTEND_ORIGIN=http://localhost:5173

# ── Upload limits ─────────────────────────────────────────────────────────────
# Maximum allowed upload size in bytes (default: 50 MB).
MAX_UPLOAD_BYTES=52428800
