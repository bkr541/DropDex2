# ── Supabase project ─────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co

# Service-role key — bypasses RLS for server-side inserts.
# Find it in: Supabase Dashboard → Settings → API → Project API Keys → service_role
# NEVER expose this value to frontend code or VITE_ variables.
SUPABASE_SECRET_KEY=

# ── JWT verification ──────────────────────────────────────────────────────────
# Modern Supabase projects use ES256 (asymmetric). No secret is needed — the
# backend fetches the public key automatically from:
#   {SUPABASE_URL}/auth/v1/.well-known/jwks.json
#
# SUPABASE_JWT_SECRET is only required for legacy HS256 projects.
# Leave it unset for any project created after mid-2024.
# SUPABASE_JWT_SECRET=

# ── CORS ─────────────────────────────────────────────────────────────────────
# Origin of the frontend dev server (or production URL).
# Only this origin is allowed to make cross-origin requests to the backend.
FRONTEND_ORIGIN=http://127.0.0.1:3000

# ── Upload limits ─────────────────────────────────────────────────────────────
# Maximum allowed upload size in bytes (default: 50 MB).
MAX_UPLOAD_BYTES=52428800
