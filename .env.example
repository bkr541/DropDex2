# ── Supabase ───────────────────────────────────────────────────────────────────
# Required for authentication and cloud library storage.

# Your Supabase project URL (safe to commit, not a secret):
VITE_SUPABASE_URL=https://your-project.supabase.co

# Anon / publishable key — safe to expose in browser JavaScript.
# Find it in: Supabase Dashboard → Project Settings → API → Project API Keys
# !! NEVER add a service_role or secret key to any VITE_-prefixed variable.
# !! VITE_ variables are bundled into public JavaScript.
VITE_SUPABASE_ANON_KEY=

# ── Import backend ─────────────────────────────────────────────────────────────
# URL of the DropDex FastAPI backend. Required for production builds.
# Local development may omit it and will use http://127.0.0.1:8000.
VITE_IMPORT_API_URL=http://127.0.0.1:8000
