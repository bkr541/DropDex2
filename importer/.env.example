# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL (same value as VITE_SUPABASE_URL in the frontend; safe to commit):
SUPABASE_URL=https://eselafyxpgsbndrcknfy.supabase.co

# Service-role / secret key — bypasses RLS for server-side inserts.
#
# !! This key MUST stay server-side / local only.
# !! Never use a VITE_-prefixed variable for this key.
# !! Never add this key to any frontend source file.
# !! Never commit this .env file to version control.
#
# Find it in: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SECRET_KEY=

# ── Import target ─────────────────────────────────────────────────────────────
# Supabase Auth user UUID that will own the imported library.
# Find it in: Supabase Dashboard → Authentication → Users → copy the UUID column.
DROPDEX_OWNER_USER_ID=

# ── Source database (optional) ────────────────────────────────────────────────
# Absolute path to your exportLibrary.db file.
# Can also be supplied as --file on the command line.
EXPORT_LIBRARY_PATH=
